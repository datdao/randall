{
  "manifest_version": 3,
  "name": "Randall",
  "version": "1.0.0",
  "description": "Click to record the current tab. Click again to stop and save.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "downloads",
    "storage"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Randall — Tab Recorder"
  }
}
